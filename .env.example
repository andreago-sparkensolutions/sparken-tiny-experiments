# Local: copy this file to `.env` and fill in values (`.env` is gitignored).
# Vercel: Project → Settings → Environment Variables → add the SAME names for Production (then redeploy).
# Values: Supabase → Project Settings → API → Project URL and anon public key.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
